# AWS SSM Connections Configuration
# Format: INI-style config file with connection sections
# Each section defines a port forwarding configuration
#
# The 'profile' field is optional. If omitted, the current AWS_PROFILE
# will be used, or you'll be prompted to select one if not authenticated.

[LocalDB]
name = Database
host = localhost
port = 5432

[Engine]
name = CheckoutEngine
host = rch-cf-rds-engine-read.rch
port = 5432
local_port = 5432

# Multi-port forwarding
# AlertManager (9093) 
# Victoria Metrics (8428) 
[Monitoring-All]
profile = ps
region = us-west-2
name = Monitoring
host = localhost
ports = 8428,9093
local_ports = 8428,9093

